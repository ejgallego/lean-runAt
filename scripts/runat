#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local source="${BASH_SOURCE[0]}"
  local dir=""
  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    case "$source" in
      /*)
        ;;
      *)
        source="$dir/$source"
        ;;
    esac
  done
  dir="$(cd -P "$(dirname "$source")" && pwd)"
  printf '%s/%s\n' "$dir" "$(basename "$source")"
}

script_path="$(resolve_script_path)"
script_dir="$(cd -P "$(dirname "$script_path")" && pwd)"
if [ -n "${RUNAT_HOME:-}" ]; then
  repo_root="$RUNAT_HOME"
  if [ -x "$repo_root/libexec/runAt-cli" ]; then
    runat_bin="$repo_root/libexec/runAt-cli"
  else
    runat_bin="$repo_root/.lake/build/bin/runAt-cli"
  fi
else
  repo_root="$(cd -P "$script_dir/.." && pwd)"
  runat_bin="$repo_root/.lake/build/bin/runAt-cli"
  if [ ! -x "$runat_bin" ] && [ -x "$repo_root/libexec/runAt-cli" ]; then
    runat_bin="$repo_root/libexec/runAt-cli"
  fi
fi

if [ ! -x "$runat_bin" ]; then
  echo "missing runAt CLI at $runat_bin" >&2
  echo "run: (cd \"$repo_root\" && lake build runAt-cli)" >&2
  exit 1
fi

export RUNAT_HOME="$repo_root"
exec "$runat_bin" "$@"
